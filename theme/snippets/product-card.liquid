{%- liquid
  assign p = product
  assign rating = p.metafields.reviews.rating.value | default: 4.8
  assign review_count = p.metafields.reviews.count.value | default: 142
  assign tagline = p.metafields.custom.tagline.value | default: p.type
-%}
<article class="product-card">
  <a href="{{ p.url }}" class="product-card__media" aria-label="{{ p.title }}">
    <div class="product-card__badges">
      {% if p.compare_at_price > p.price %}
        <span class="pill pill-accent">−{{ p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price }}%</span>
      {% endif %}
      {% if p.tags contains 'new' %}<span class="pill pill-soft">New</span>{% endif %}
      {% if p.tags contains 'bestseller' %}<span class="pill pill-soft">Bestseller</span>{% endif %}
    </div>
    {% if p.featured_image %}
      <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}" loading="lazy">
    {% else %}
      <img src="https://images.unsplash.com/photo-1556228720-195a672e8a03?w=600&q=80" alt="{{ p.title }}" loading="lazy">
    {% endif %}
    <div class="product-card__quick">
      <button class="btn btn-primary btn-block btn-sm" data-add-to-cart data-label="Add to bag" type="button">Quick add</button>
    </div>
  </a>
  <div>
    <span class="product-card__sub">{{ tagline }}</span>
    <h3 class="product-card__title"><a href="{{ p.url }}">{{ p.title }}</a></h3>
    <span class="rating">
      <span class="rating__stars">{% for i in (1..5) %}★{% endfor %}</span>
      {{ rating }} ({{ review_count }})
    </span>
    {% render 'price', product: p %}
  </div>
</article>
