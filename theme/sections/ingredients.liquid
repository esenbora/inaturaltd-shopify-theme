<section class="ingredients section">
  <div class="wrap">
    <header class="section-head section-head--center text-center mx-auto">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Our quality marks' }}</span>
      <h2 class="h2">{{ section.settings.heading | default: 'Certified, not just claimed.' }}</h2>
      <p class="lead muted">{{ section.settings.subheading | default: 'Five independent certifications behind every INCIA formula — checked, audited and renewed annually.' }}</p>
    </header>

    <div class="grid ingredient-grid">
      {% for block in section.blocks %}
        <div class="ingredient" {{ block.shopify_attributes }}>
          <div class="ingredient__media">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" width="400" height="400">
            {% else %}
              <img src="{{ block.settings.fallback_url }}" alt="{{ block.settings.title }}" width="400" height="400">
            {% endif %}
          </div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      {% else %}
        <div class="ingredient">
          <div class="ingredient__media" style="display: grid; place-items: center; background: linear-gradient(135deg, #EFE7D6, #F8F4ED);">
            <svg width="60" height="60" viewBox="0 0 80 80" fill="none" stroke="#5A7C5D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="40" cy="40" r="32"/>
              <path d="M40 18 C 30 30 30 50 40 62 C 50 50 50 30 40 18 Z"/>
              <path d="M40 18 L 40 62" stroke-width="1.5"/>
            </svg>
          </div>
          <h4>ETKO Cosmos</h4><p>Strict natural &amp; organic cosmetics standard. Audited every 12 months.</p>
        </div>
        <div class="ingredient">
          <div class="ingredient__media" style="display: grid; place-items: center; background: linear-gradient(135deg, #EFE7D6, #F8F4ED);">
            <svg width="60" height="60" viewBox="0 0 80 80" fill="none" stroke="#5A7C5D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M40 12 L 56 22 L 56 42 C 56 56 40 68 40 68 C 40 68 24 56 24 42 L 24 22 Z"/>
              <path d="M32 40 L 38 46 L 50 32"/>
            </svg>
          </div>
          <h4>BioArge</h4><p>Certified organic &amp; environmentally friendly R&amp;D process.</p>
        </div>
        <div class="ingredient">
          <div class="ingredient__media" style="display: grid; place-items: center; background: linear-gradient(135deg, #EFE7D6, #F8F4ED);">
            <svg width="60" height="60" viewBox="0 0 80 80" fill="none" stroke="#5A7C5D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M40 14 C 28 14 22 22 24 32 C 26 40 32 44 40 44 C 48 44 54 40 56 32 C 58 22 52 14 40 14 Z"/>
              <path d="M40 44 L 40 66" stroke-width="2"/>
              <path d="M32 56 L 48 56" stroke-width="2"/>
            </svg>
          </div>
          <h4>Vegan</h4><p>Plant-based, animal-derived-free, effective on eczema-prone skin.</p>
        </div>
        <div class="ingredient">
          <div class="ingredient__media" style="display: grid; place-items: center; background: linear-gradient(135deg, #EFE7D6, #F8F4ED);">
            <svg width="60" height="60" viewBox="0 0 80 80" fill="none" stroke="#5A7C5D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M28 36 C 22 32 20 24 24 18 C 30 14 36 18 38 22 M 52 36 C 58 32 60 24 56 18 C 50 14 44 18 42 22"/>
              <ellipse cx="40" cy="46" rx="18" ry="14"/>
              <circle cx="34" cy="44" r="2" fill="#5A7C5D"/>
              <circle cx="46" cy="44" r="2" fill="#5A7C5D"/>
              <path d="M36 52 Q 40 56 44 52"/>
            </svg>
          </div>
          <h4>Cruelty-Free</h4><p>No animal testing — not in research, not in production. Ever.</p>
        </div>
        <div class="ingredient">
          <div class="ingredient__media" style="display: grid; place-items: center; background: linear-gradient(135deg, #EFE7D6, #F8F4ED);">
            <svg width="60" height="60" viewBox="0 0 80 80" fill="none" stroke="#5A7C5D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="40" cy="28" r="10"/>
              <path d="M22 64 C 22 50 30 42 40 42 C 50 42 58 50 58 64"/>
              <path d="M32 22 Q 40 14 48 22" stroke-width="1.5"/>
            </svg>
          </div>
          <h4>Baby-Friendly</h4><p>Safe for mom &amp; baby — gentle enough for newborn skin.</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredient spotlight",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_url", "label": "Fallback image URL" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [{ "name": "Ingredients" }]
}
{% endschema %}
