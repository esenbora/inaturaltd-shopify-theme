<section class="testimonials section">
  <div class="wrap">
    <header class="section-head section-head--center text-center mx-auto" style="color: var(--bg);">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Reviews' }}</span>
      <h2 class="h2" style="color: var(--bg);">{{ section.settings.heading | default: '5-star rated — trusted by 50,000+ across Europe.' }}</h2>
    </header>

    <div class="grid testimonials__grid">
      {% for block in section.blocks %}
        <article class="testimonial" {{ block.shopify_attributes }}>
          <span class="rating__stars" style="color: var(--accent); letter-spacing: 2px;">★★★★★</span>
          <p class="testimonial__quote">“{{ block.settings.quote }}”</p>
          <div class="testimonial__author">
            <span class="testimonial__avatar">{{ block.settings.name | slice: 0, 1 }}</span>
            <div>
              <div class="testimonial__name">{{ block.settings.name }}</div>
              <div class="testimonial__verified">{% render 'icon', name: 'check' %} Verified buyer · {{ block.settings.product }}</div>
            </div>
          </div>
        </article>
      {% else %}
        <article class="testimonial">
          <span class="rating__stars" style="color: var(--accent); letter-spacing: 2px;">★★★★★</span>
          <p class="testimonial__quote">"Lovely, this sunscreen is great. It's light on the skin and it smells lovely. I love the fact that it is made of natural ingredients and it can be used by all of my family without worrying about what is in it."</p>
          <div class="testimonial__author">
            <span class="testimonial__avatar">C</span>
            <div>
              <div class="testimonial__name">Charlie Eaton</div>
              <div class="testimonial__verified">✓ Verified buyer · INCIA Natural Sunscreen</div>
            </div>
          </div>
        </article>
        <article class="testimonial">
          <span class="rating__stars" style="color: var(--accent); letter-spacing: 2px;">★★★★★</span>
          <p class="testimonial__quote">"Best baby laundry ever. My son has very sensitive skin, so we can't use just any product. We chose this one because it has natural ingredients, and we absolutely love it. We've been using it safely for a long time."</p>
          <div class="testimonial__author">
            <span class="testimonial__avatar">M</span>
            <div>
              <div class="testimonial__name">Merve Erk</div>
              <div class="testimonial__verified">✓ Verified buyer · INCIA Baby &amp; Kids Shampoo</div>
            </div>
          </div>
        </article>
        <article class="testimonial">
          <span class="rating__stars" style="color: var(--accent); letter-spacing: 2px;">★★★★★</span>
          <p class="testimonial__quote">"My first item was lost by the courier, but the customer service team at INature kept me informed every step of the way. A lovely natural deodorant which smells gorgeous. I will definitely buy more. 100% recommended."</p>
          <div class="testimonial__author">
            <span class="testimonial__avatar">C</span>
            <div>
              <div class="testimonial__name">Charlie Eaton</div>
              <div class="testimonial__verified">✓ Verified buyer · INCIA Natural Deodorant</div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "product", "label": "Product purchased" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
