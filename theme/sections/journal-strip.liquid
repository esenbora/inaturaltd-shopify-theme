<section class="section">
  <div class="wrap">
    <header class="section-head section-head--split">
      <div class="stack" style="--gap: var(--space-3);">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Journal' }}</span>
        <h2 class="h2">{{ section.settings.heading | default: 'Slow notes on rituals, ingredients & places.' }}</h2>
      </div>
      <a href="/blogs/journal" class="btn btn-outline">All articles {% render 'icon', name: 'arrow-right' %}</a>
    </header>

    <div class="grid" style="grid-template-columns: repeat(3, 1fr); --gap: var(--space-6);">
      {% for block in section.blocks %}
        <article class="stack" style="--gap: var(--space-3);" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.url | default: '#' }}" class="product-card__media" style="aspect-ratio: 4/3;">
            <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title }}" loading="lazy" width="600" height="450">
          </a>
          <span class="product-card__sub">{{ block.settings.tag }} · {{ block.settings.read }} min read</span>
          <h3 class="h4"><a href="{{ block.settings.url | default: '#' }}">{{ block.settings.title }}</a></h3>
          <p class="muted" style="font-size: var(--fs-sm);">{{ block.settings.excerpt }}</p>
        </article>
      {% else %}
        <article class="stack" style="--gap: var(--space-3);">
          <a href="#" class="product-card__media" style="aspect-ratio: 4/3;">
            <img src="https://images.unsplash.com/photo-1556228852-80b6e5eeff06?w=600&q=85" alt="" loading="lazy" width="600" height="450">
          </a>
          <span class="product-card__sub">Baby &amp; pregnancy · 5 min read</span>
          <h3 class="h4"><a href="#">Why we wrap the Newborn Gift Set ourselves.</a></h3>
          <p class="muted" style="font-size: var(--fs-sm);">100% natural care for baby and mom — every gift includes a handwritten note and a list of which products to use when.</p>
        </article>
        <article class="stack" style="--gap: var(--space-3);">
          <a href="#" class="product-card__media" style="aspect-ratio: 4/3;">
            <img src="https://images.unsplash.com/photo-1556228720-8c5d6b06bd17?w=600&q=85" alt="" loading="lazy" width="600" height="450">
          </a>
          <span class="product-card__sub">Eczema care · 6 min read</span>
          <h3 class="h4"><a href="#">Real customer transformations with INCIA Intensive Repair.</a></h3>
          <p class="muted" style="font-size: var(--fs-sm);">From redness and itching to calm, healthy skin. See the before-and-after photos and routine notes that come with the cream.</p>
        </article>
        <article class="stack" style="--gap: var(--space-3);">
          <a href="#" class="product-card__media" style="aspect-ratio: 4/3;">
            <img src="https://images.unsplash.com/photo-1571781926291-c477ebfd024b?w=600&q=85" alt="" loading="lazy" width="600" height="450">
          </a>
          <span class="product-card__sub">Behind the brand · 4 min read</span>
          <h3 class="h4"><a href="#">Türkiye → NL → BE → UK: how INCIA crossed Europe.</a></h3>
          <p class="muted" style="font-size: var(--fs-sm);">The same shelf in ETOS, now on your shelf in the UK. How INature became INCIA&apos;s official UK distributor in 2024.</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journal strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "tag", "label": "Tag" },
        { "type": "number", "id": "read", "label": "Read time (minutes)" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "excerpt", "label": "Excerpt" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "Journal strip" }]
}
{% endschema %}
