        price: '5.95',
        rating: '4.9',
        reviews: '412',
        url: '/products/incia-lip-balm-coconut' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "presets": [{ "name": "Related products" }]
}
{% endschema %}
