        sub: 'Aluminium-free · 50 ml',
        price: '5.95',
        was: '6.50',
        rating: '4.9',
        reviews: '318',
        badge: 'Bestseller',
        url: '/products/incia-natural-deodorant-for-sensitive-skin' %}
      {% render 'mock-product-card',
        image: 'https://static.wixstatic.com/media/bf3c53_551d911bd3eb484abab1a56a6f509b8d~mv2.png/v1/fill/w_600,h_600,al_c,q_85/bf3c53_551d911bd3eb484abab1a56a6f509b8d~mv2.png',
