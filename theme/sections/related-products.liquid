<section class="section">
  <div class="wrap">
    <header class="section-head section-head--center text-center mx-auto">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Pairs well with' }}</span>
      <h2 class="h2">{{ section.settings.heading | default: 'Build the routine.' }}</h2>
    </header>
    <div class="grid product-grid">
      {% render 'mock-product-card',
        image: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?w=600&q=85',
        title: 'INCIA Natural Deodorant for Sensitive Skin',
        sub: 'Aluminium-free · 50 ml',
        price: '5.95',
        was: '6.50',
        rating: '4.9',
        reviews: '318',
        badge: 'Bestseller',
        url: '/products/incia-natural-deodorant-for-sensitive-skin' %}
      {% render 'mock-product-card',
        image: 'https://images.unsplash.com/photo-1620916566398-39f1143ab7be?w=600&q=85',
        title: 'INCIA Natural Hair Serum',
        sub: '10 oils · 30 ml',
        price: '10.45',
        rating: '4.8',
        reviews: '147',
        url: '/products/incia-natural-hair-serum' %}
      {% render 'mock-product-card',
        image: 'https://images.unsplash.com/photo-1556228720-195a672e8a03?w=600&q=85',
        title: 'INCIA Natural Sunscreen for Face SPF50',
        sub: 'Mineral sunscreen · 50 ml',
        price: '12',
        was: '15',
        rating: '4.9',
        reviews: '188',
        badge: 'SPF50',
        url: '/products/incia-natural-sunscreen-for-face-spf50' %}
      {% render 'mock-product-card',
        image: 'https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?w=600&q=85',
        title: 'INCIA Lip Balm Coconut',
        sub: 'Natural lip balm · 5 ml',
        price: '5.95',
        rating: '4.9',
        reviews: '412',
        url: '/products/incia-lip-balm-coconut' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "presets": [{ "name": "Related products" }]
}
{% endschema %}
