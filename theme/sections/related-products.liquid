<section class="section">
  <div class="wrap">
    <header class="section-head section-head--center text-center mx-auto">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Pairs well with' }}</span>
      <h2 class="h2">{{ section.settings.heading | default: 'Build the routine.' }}</h2>
    </header>
    <div class="grid product-grid">
      {% render 'mock-product-card',
        image: 'https://static.wixstatic.com/media/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp',
        title: 'INCIA Natural Deodorant for Sensitive Skin',
        sub: 'Aluminium-free roll-on with potassium alum & aloe vera · Safe in pregnancy · 50 ml',
        price: '5.95',
        was: '6.50',
        rating: '4.9',
        reviews: '318',
        badge: 'Bestseller',
        url: '/products/incia-natural-deodorant-for-sensitive-skin' %}
      {% render 'mock-product-card',
        image: 'https://static.wixstatic.com/media/bf3c53_4f6e35bf0c9d4faeb9cd42f38776235c~mv2.jpg/v1/fill/w_600,h_600,al_c,q_85/bf3c53_4f6e35bf0c9d4faeb9cd42f38776235c~mv2.jpg',
        title: 'INCIA Natural Hair Serum',
        sub: '10 cold-pressed oils — argan, almond, olive · Strengthens & restores shine · Silicone-free · 30 ml',
        price: '10.45',
        rating: '4.8',
        reviews: '147',
        url: '/products/incia-natural-hair-serum' %}
      {% render 'mock-product-card',
        image: 'https://static.wixstatic.com/media/bf3c53_47d622abb70842b99bbcda1517ff2dc4~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_47d622abb70842b99bbcda1517ff2dc4~mv2.webp',
