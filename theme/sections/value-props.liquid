<section class="section">
  <div class="wrap">
    <header class="section-head section-head--center text-center mx-auto">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Why INature' }}</span>
      <h2 class="h2">{{ section.settings.heading | default: 'Naturals you can actually trust.' }}</h2>
      <p class="lead muted">{{ section.settings.subheading | default: 'Every INCIA formula is 100% natural, dermatologically tested, and certified — already loved across Europe for over five years.' }}</p>
    </header>

    <div class="grid values">
      {% for block in section.blocks %}
        <div class="value-card" {{ block.shopify_attributes }}>
          <div class="value-card__icon">{% render 'icon', name: block.settings.icon %}</div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      {% else %}
        <div class="value-card"><div class="value-card__icon">{% render 'icon', name: 'leaf' %}</div><h4>100% natural formulas</h4><p>Plant-derived actives, mineral filters and botanical oils — never synthetic alternatives. All ingredients of natural origin.</p></div>
        <div class="value-card"><div class="value-card__icon">{% render 'icon', name: 'shield' %}</div><h4>Safe for babies &amp; sensitive skin</h4><p>Free from SLS, parabens, fluoride, mineral oils and synthetic fragrances. Dermatologically tested, eczema-friendly.</p></div>
        <div class="value-card"><div class="value-card__icon">{% render 'icon', name: 'sparkle' %}</div><h4>Certified, not just claimed</h4><p>ETKO Cosmos, BioArge, Vegan and Cruelty-Free certifications. Same formulas trusted by ETOS in the Netherlands.</p></div>
        <div class="value-card"><div class="value-card__icon">{% render 'icon', name: 'truck' %}</div><h4>Shipped via Evri from UK</h4><p>Dispatched promptly from the UK. Free shipping over £20, £3 below. 14-day returns, no questions.</p></div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value props",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "leaf",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "shield", "label": "Shield" },
            { "value": "recycle", "label": "Recycle" },
            { "value": "truck", "label": "Truck" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "heart", "label": "Heart" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{ "name": "Value props" }]
}
{% endschema %}
