<section class="hero">
  <div class="wrap hero__inner">
    <div class="hero__content stack" style="--gap: var(--space-5);">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="h-display hero__title">{{ section.settings.heading | default: 'Skincare with <em>roots</em>, made for modern routines.' }}</h1>
      <p class="lead">{{ section.settings.subheading | default: 'INCIA''s 100% natural, ETKO Cosmos-certified formulas. Trusted by 50,000+ families across Europe — now distributed to the UK by INature.' }}</p>
      <div class="cluster" style="--gap: var(--space-3);">
        <a href="{{ section.settings.cta_primary_url | default: routes.all_products_collection_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_primary_label | default: 'Shop bestsellers' }}
          {% render 'icon', name: 'arrow-right' %}
        </a>
        <a href="{{ section.settings.cta_secondary_url | default: '/pages/about' }}" class="btn btn-ghost btn-lg">{{ section.settings.cta_secondary_label | default: 'Why INature' }}</a>
      </div>
      <ul class="cluster muted" style="--gap: var(--space-5); font-size: var(--fs-sm); margin-top: var(--space-4);">
        <li class="cluster" style="--gap: 6px;">{% render 'icon', name: 'check' %} ETKO Cosmos certified</li>
        <li class="cluster" style="--gap: 6px;">{% render 'icon', name: 'check' %} Vegan & cruelty-free</li>
        <li class="cluster" style="--gap: 6px;">{% render 'icon', name: 'check' %} Free UK delivery £20+</li>
      </ul>
    </div>

    <div class="hero__media">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 900 }}" alt="" width="900" height="1125">
      {% else %}
        <img src="https://static.wixstatic.com/media/bf3c53_725854f8f31c41b29702a8de321aa7ae~mv2.webp/v1/fill/w_900,h_1125,al_c,q_90/bf3c53_725854f8f31c41b29702a8de321aa7ae~mv2.webp" alt="Natural skincare bottle on a marble surface with eucalyptus leaves" width="900" height="1125">
      {% endif %}
      <div class="hero__sticker">
        Trusted by<br>50,000+<br>in Europe
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Naturals — UK collection" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Skincare with <em>roots</em>, made for modern routines.</p>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "cta_primary_label", "label": "Primary CTA label", "default": "Shop the edit" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Read our story" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
