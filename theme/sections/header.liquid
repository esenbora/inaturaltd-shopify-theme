<header class="site-header" data-header>
  <div class="wrap site-header__inner">
    <nav class="site-header__nav" aria-label="Primary">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.all_products_collection_url }}">Shop all</a>
        <a href="/collections/baby-pregnancy">Baby &amp; Pregnancy</a>
        <a href="/collections/personal-care">Personal Care</a>
        <a href="/collections/sun-care">Sun Care</a>
        <a href="/pages/about">Story</a>
      {% endfor %}
    </nav>

    <a href="{{ routes.root_url }}" class="brand-mark" aria-label="{{ shop.name }} home"><span class="brand-i">I</span><span class="brand-leaf-wrap"><span class="brand-verb" data-brand-verb>am</span><svg class="brand-leaf" width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M3 28 C 3 14, 14 3, 28 4 C 28 18, 18 28, 3 28 Z" fill="#7BC940"/><path d="M28 4 C 22 12, 13 22, 5 27" stroke="#5A9F2C" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg></span><span class="brand-nature">Nature</span></a>

    <div class="site-header__actions">
      <button class="icon-btn" aria-label="Search" type="button">
        {% render 'icon', name: 'search' %}
      </button>
      <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">
        {% render 'icon', name: 'user' %}
      </a>
      <button class="icon-btn" data-cart-open aria-label="Open cart" type="button">
        {% render 'icon', name: 'bag' %}
        <span class="count">{{ cart.item_count | default: 2 }}</span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
