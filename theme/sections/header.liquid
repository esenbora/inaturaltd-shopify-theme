<header class="site-header" data-header>
  <div class="wrap site-header__inner">
    <nav class="site-header__nav" aria-label="Primary">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.all_products_collection_url }}">Shop all</a>
        <a href="/collections/baby-pregnancy">Baby &amp; Pregnancy</a>
        <a href="/collections/personal-care">Personal Care</a>
        <a href="/collections/sun-care">Sun Care</a>
        <a href="/pages/about">Story</a>
      {% endfor %}
    </nav>

    <a href="{{ routes.root_url }}" class="brand-mark" aria-label="{{ shop.name }} home"><svg class="brand-leaf" width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 4 C10 8 7 14 8 22 C16 22 23 17 25 11 C24 7 21 5 16 4 Z" fill="currentColor" fill-opacity="0.18"/><path d="M18 6 C17 12 14 18 9 22"/></svg>INature</a>

    <div class="site-header__actions">
      <button class="icon-btn" aria-label="Search" type="button">
        {% render 'icon', name: 'search' %}
      </button>
      <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">
        {% render 'icon', name: 'user' %}
      </a>
      <button class="icon-btn" data-cart-open aria-label="Open cart" type="button">
        {% render 'icon', name: 'bag' %}
        <span class="count">{{ cart.item_count | default: 2 }}</span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
