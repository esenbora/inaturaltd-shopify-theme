<section class="section">
  <div class="wrap">
    <header class="section-head section-head--split">
      <div class="stack" style="--gap: var(--space-3);">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Edit' }}</span>
        <h2 class="h2">{{ section.settings.heading | default: 'Bestsellers across the INCIA range.' }}</h2>
      </div>
      <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="btn btn-outline">{{ section.settings.cta_label | default: 'Shop all' }} {% render 'icon', name: 'arrow-right' %}</a>
    </header>

    <div class="grid product-grid">
      {%- assign collection_obj = collections[section.settings.collection] -%}
      {%- if collection_obj.products.size > 0 -%}
        {% for product in collection_obj.products limit: 8 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {%- else -%}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp',
          title: 'INCIA Natural Deodorant for Sensitive Skin',
          sub: 'Aluminium-free roll-on with potassium alum & aloe vera · Safe in pregnancy · 50 ml',
          price: '5.95',
          was: '6.50',
          rating: '4.9',
          reviews: '318',
          badge: 'Bestseller',
          url: '/products/incia-natural-deodorant-for-sensitive-skin' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_93c25fe67c184c8fadae0a006b289efa~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_93c25fe67c184c8fadae0a006b289efa~mv2.webp',
          title: 'INCIA SOS Stick',
          sub: 'Multi-purpose healing balm with sea buckthorn, shea & St. John''s Wort · For cracked, dry skin · 9.5 g',
          price: '9.50',
          rating: '4.9',
          reviews: '204',
          badge: '9 oils',
          url: '/products/incia-sos-stick' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_4f6e35bf0c9d4faeb9cd42f38776235c~mv2.jpg/v1/fill/w_600,h_600,al_c,q_85/bf3c53_4f6e35bf0c9d4faeb9cd42f38776235c~mv2.jpg',
          title: 'INCIA Natural Hair Serum',
          sub: '10 cold-pressed oils — argan, almond, olive · Strengthens & restores shine · Silicone-free · 30 ml',
          price: '10.45',
          rating: '4.8',
          reviews: '147',
          badge: '10 oils',
          url: '/products/incia-natural-hair-serum' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_725854f8f31c41b29702a8de321aa7ae~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_725854f8f31c41b29702a8de321aa7ae~mv2.webp',
          title: 'INCIA Foaming Facial Cleanser',
          sub: 'Plant-derived foaming cleanser — gentle, no SLS, no parabens · For sensitive skin · 200 ml',
          price: '8',
          was: '10',
          rating: '4.7',
          reviews: '256',
          url: '/products/incia-foaming-facial-cleanser' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_47d622abb70842b99bbcda1517ff2dc4~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_47d622abb70842b99bbcda1517ff2dc4~mv2.webp',
          title: 'INCIA Natural Sunscreen for Face SPF50',
          sub: 'SPF50 mineral face sunscreen with hyaluronic acid · Ecocert non-nano · Anti-ageing · 50 ml',
          price: '12',
          was: '15',
          rating: '4.9',
          reviews: '188',
          badge: 'SPF50',
          url: '/products/incia-natural-sunscreen-for-face-spf50' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_b6212b6355fb434f9fa499b58ec5293c~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_b6212b6355fb434f9fa499b58ec5293c~mv2.webp',
          title: 'INCIA Lip Balm Coconut',
          sub: '100% natural coconut lip balm · Soothes dry, chapped lips · Halal · 5 ml',
          price: '5.95',
          rating: '4.9',
          reviews: '412',
          badge: 'Free gift £12+',
          url: '/products/incia-lip-balm-coconut' %}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_2124fee16f9b4d19a6aab711629f7989~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_2124fee16f9b4d19a6aab711629f7989~mv2.webp',
          title: 'INCIA Stretch Mark Gel Cream',
          sub: 'Pregnancy-safe gel cream · Prevents & fades stretch marks · Dermatologically tested · 75 ml',
