          image: 'https://static.wixstatic.com/media/bf3c53_8778d360bc3b480ab28c0673bf09dcd2~mv2.jpg/v1/fill/w_600,h_600,al_c,q_85/bf3c53_8778d360bc3b480ab28c0673bf09dcd2~mv2.jpg',
          title: 'INCIA Natural Toothpaste',
          sub: 'Fluoride-free toothpaste · Xylitol fights cavities · Cinnamon & coconut · SLS-free · 50 ml',
          price: '7',
          rating: '4.7',
          reviews: '231',
          badge: 'Fluoride-free',
          url: '/products/incia-natural-toothpaste' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Edit" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop all" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
