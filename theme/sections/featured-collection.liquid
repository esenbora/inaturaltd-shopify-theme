<section class="section">
  <div class="wrap">
    <header class="section-head section-head--split">
      <div class="stack" style="--gap: var(--space-3);">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'The Edit' }}</span>
        <h2 class="h2">{{ section.settings.heading | default: 'Bestsellers, hand-picked weekly.' }}</h2>
      </div>
      <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="btn btn-outline">{{ section.settings.cta_label | default: 'Shop all' }} {% render 'icon', name: 'arrow-right' %}</a>
    </header>

    <div class="grid product-grid">
      {%- assign collection_obj = collections[section.settings.collection] -%}
      {%- if collection_obj.products.size > 0 -%}
        {% for product in collection_obj.products limit: 8 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {%- else -%}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1612817288484-6f916006741a?w=600&q=85',
          title: 'Rose & Hyaluronic Glow Serum',
          sub: 'Hydrating serum · 30 ml',
          price: '32',
          rating: '4.9',
          reviews: '286',
          badge: 'Bestseller',
          url: '/products/rose-glow-serum' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1617897903246-719242758050?w=600&q=85',
          title: 'Olive Leaf Cleansing Bar',
          sub: 'Solid cleanser · 100 g',
          price: '12',
          was: '15',
          rating: '4.8',
          reviews: '412',
          badge: 'Plastic-free',
          url: '/products/olive-leaf-bar' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1556228720-195a672e8a03?w=600&q=85',
          title: 'Pistachio Body Butter',
          sub: 'Rich body cream · 200 ml',
          price: '28',
          rating: '4.9',
          reviews: '198',
          url: '/products/pistachio-body-butter' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?w=600&q=85',
          title: 'Propolis Repair Balm',
          sub: 'Multi-balm · 50 ml',
          price: '24',
          rating: '4.9',
          reviews: '342',
          badge: 'New',
          url: '/products/propolis-balm' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1620916566398-39f1143ab7be?w=600&q=85',
          title: 'Damask Rose Toner',
          sub: 'Hydrosol toner · 200 ml',
          price: '22',
          rating: '4.8',
          reviews: '167',
          url: '/products/rose-toner' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1601612628452-9e99ced43524?w=600&q=85',
          title: 'Olive & Lavender Shampoo',
          sub: 'Gentle shampoo · 250 ml',
          price: '18',
          rating: '4.7',
          reviews: '254',
          url: '/products/olive-shampoo' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1625772452859-1c03d5bf1137?w=600&q=85',
          title: 'Black Cumin Night Oil',
          sub: 'Facial oil · 30 ml',
          price: '36',
          rating: '5.0',
          reviews: '92',
          badge: 'New',
          url: '/products/black-cumin-night-oil' %}
        {% render 'mock-product-card',
          image: 'https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?w=600&q=85',
          title: 'Calendula Hand Cream',
          sub: 'Hand cream · 75 ml',
          price: '14',
          rating: '4.8',
          reviews: '521',
          url: '/products/calendula-hand-cream' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Edit" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop all" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
