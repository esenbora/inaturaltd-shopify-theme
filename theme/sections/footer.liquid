<footer class="site-footer">
  <div class="wrap">
    <div class="site-footer__grid">
      <div>
        <span class="brand-mark"><span class="brand-i">I</span><span class="brand-leaf-wrap"><span class="brand-verb" data-brand-verb>am</span><svg class="brand-leaf" width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path d="M3 28 C 3 14, 14 3, 28 4 C 28 18, 18 28, 3 28 Z" fill="#7BC940"/><path d="M28 4 C 22 12, 13 22, 5 27" stroke="#5A9F2C" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg></span><span class="brand-nature">Nature</span></span>
        <p style="font-size: var(--fs-sm); color: rgba(248,244,237,.7); max-width: 38ch;">
          {{ section.settings.about_text | default: '100% natural skincare from Türkiye, dispatched in the UK. The official UK distributor of INCIA Naturals — trusted by 50,000+ families across Europe.' }}
        </p>
        <div class="site-footer__social mt-4">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" aria-label="TikTok">{% render 'icon', name: 'tiktok' %}</a>
          {% endif %}
          {% if settings.social_facebook != blank %}
            <a href="{{ settings.social_facebook }}" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>
          {% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div {{ block.shopify_attributes }}>
            <h5>{{ block.settings.title }}</h5>
            <ul class="site-footer__links">
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% else %}
                {% if block.settings.title contains 'Shop' %}
                  <li><a href="/collections/bestsellers">Bestsellers</a></li>
                  <li><a href="/collections/baby-pregnancy">Baby &amp; Pregnancy</a></li>
                  <li><a href="/collections/personal-care">Personal Care</a></li>
                  <li><a href="/collections/sun-care">Sun Care</a></li>
                  <li><a href="/collections/sale">Sale</a></li>
                {% elsif block.settings.title contains 'Help' %}
                  <li><a href="/pages/shipping-and-returns">Shipping &amp; returns</a></li>
                  <li><a href="/pages/faq">FAQ</a></li>
                  <li><a href="/pages/contact">Contact us</a></li>
                  <li><a href="{{ routes.account_url }}">My account</a></li>
                  <li><a href="/pages/track-order">Track order</a></li>
                {% else %}
                  <li><a href="/pages/about">Our story</a></li>
                  <li><a href="/pages/quality-marks">Quality marks</a></li>
                  <li><a href="/pages/incia-in-europe">INCIA in Europe</a></li>
                  <li><a href="/pages/wholesale">Wholesale</a></li>
                  <li><a href="/pages/press">Press</a></li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% else %}
        <div>
          <h5>Shop</h5>
          <ul class="site-footer__links">
            <li><a href="/collections/bestsellers">Bestsellers</a></li>
            <li><a href="/collections/baby-pregnancy">Baby &amp; Pregnancy</a></li>
            <li><a href="/collections/personal-care">Personal Care</a></li>
            <li><a href="/collections/sun-care">Sun Care</a></li>
            <li><a href="/collections/sale">Sale</a></li>
          </ul>
        </div>
        <div>
          <h5>Help</h5>
          <ul class="site-footer__links">
            <li><a href="/pages/shipping-and-returns">Shipping &amp; returns</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/contact">Contact us</a></li>
            <li><a href="{{ routes.account_url }}">My account</a></li>
            <li><a href="/pages/track-order">Track order</a></li>
          </ul>
        </div>
        <div>
          <h5>Brand</h5>
          <ul class="site-footer__links">
            <li><a href="/pages/about">Our story</a></li>
            <li><a href="/pages/quality-marks">Quality marks</a></li>
            <li><a href="/pages/incia-in-europe">INCIA in Europe</a></li>
            <li><a href="/pages/wholesale">Wholesale</a></li>
            <li><a href="/pages/press">Press</a></li>
          </ul>
        </div>
      {% endfor %}
    </div>

    <div class="site-footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }} · Official UK distributor of INCIA Naturals</span>
      <span>Free UK shipping over £20 · 14-day returns · info@inatureltd.com</span>
      <span>
        <a href="/policies/privacy-policy">Privacy</a> ·
        <a href="/policies/terms-of-service">Terms</a> ·
        <a href="/policies/refund-policy">Refunds</a>
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "about_text", "label": "About text" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4,
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
