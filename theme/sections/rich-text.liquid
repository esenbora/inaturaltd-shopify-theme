<section class="section">
  <div class="wrap" style="max-width: 720px;">
    {% if page.title %}<h1 class="h1 mb-5">{{ page.title }}</h1>{% endif %}
    <div class="flow" style="--flow: 1.2em; line-height: 1.7;">
      {{ page.content | default: section.settings.body }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "richtext", "id": "body", "label": "Body" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
