<section class="section">
  <div class="wrap">
    <div class="editorial {% if section.settings.media_position == 'right' %}editorial--reverse{% endif %}">
      <div class="editorial__media">
        {% if section.settings.image %}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image.alt }}" width="900" height="1125">
        {% else %}
          <img src="https://images.unsplash.com/photo-1556228841-7df40d6f3a93?w=900&q=85" alt="Olive grove in the Aegean region of Türkiye" width="900" height="1125">
        {% endif %}
      </div>
      <div class="stack" style="--gap: var(--space-4); max-width: 50ch;">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'Our story' }}</span>
        <h2 class="h2">{{ section.settings.heading | default: 'Trusted in Europe for 5 years. Now ready for your family in the UK.' }}</h2>
        <div class="muted flow" style="--flow: 1em; line-height: 1.7;">
          {{ section.settings.body | default: '<p>Seyda and Ferhat brought their trust in INCIA''s natural and eco-friendly products from Türkiye to the UK. They realised how difficult it was for friends with newborns to find truly natural, safe products in Britain.</p><p>INCIA is already trusted across Europe through HemNature — including retail partnerships with ETOS in the Netherlands. INature was created to make these same clean, gentle, 100% natural products accessible to families across the UK.</p><p><strong>INature is the official UK distributor of INCIA.</strong></p>' }}
        </div>
        <div class="cluster" style="--gap: var(--space-3);">
          <a href="{{ section.settings.cta_url | default: '/pages/about' }}" class="btn btn-outline">{{ section.settings.cta_label | default: 'Read the full story' }} {% render 'icon', name: 'arrow-right' %}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "media_position", "label": "Media position",
      "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }],
      "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Editorial" }]
}
{% endschema %}
