<section class="collection-hero">
  <div class="wrap">
    <span class="eyebrow">{{ collection.title | default: 'All products' }}</span>
    <h1 class="h1 mt-3">{{ collection.title | default: 'The full INCIA range, distributed in the UK.' }}</h1>
    {% if collection.description != blank %}
      <p class="lead muted mt-3 mx-auto" style="max-width: 60ch;">{{ collection.description }}</p>
    {% else %}
      <p class="lead muted mt-3 mx-auto" style="max-width: 60ch;">31 natural products from INCIA — already trusted across Europe for over 5 years. Now dispatched from the UK by INature.</p>
    {% endif %}
  </div>
</section>

<section>
  <div class="wrap">
    <div class="collection-toolbar">
      <div class="filter-pills">
        <button class="pill pill-soft" type="button">All (31)</button>
        <button class="pill" type="button">Bestsellers</button>
        <button class="pill" type="button">Baby &amp; Pregnancy</button>
        <button class="pill" type="button">Personal Care</button>
        <button class="pill" type="button">Sun Care</button>
        <button class="pill" type="button">Household</button>
        <button class="pill" type="button">Sale</button>
      </div>
      <div class="cluster" style="--gap: var(--space-2);">
        <span class="muted" style="font-size: var(--fs-sm);">{{ collection.products_count | default: 31 }} products</span>
        <select aria-label="Sort">
          <option>Sort: Featured</option>
          <option>Bestsellers</option>
          <option>Newest</option>
          <option>Price: low to high</option>
          <option>Price: high to low</option>
        </select>
      </div>
    </div>

    <div class="grid product-grid">
      {%- if collection.products.size > 0 -%}
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {%- else -%}
        {% render 'mock-product-card',
          image: 'https://static.wixstatic.com/media/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp/v1/fill/w_600,h_600,al_c,q_85/bf3c53_3f63a6bb7a204965ad128ad9ade77c05~mv2.webp',
