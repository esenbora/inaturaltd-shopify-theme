{%- liquid
  assign p = product
  assign mock = false
  if product == blank or product.title == blank
    assign mock = true
  endif

  if mock
    assign p_title = section.settings.mock_title | default: 'INCIA SOS Stick'
    assign p_vendor = 'INCIA · By INature UK'
    assign p_subtitle = 'Intensive Natural Healing Balm · 9 botanical oils · 9.5 g solid stick'
    assign p_price = '£9.50'
    assign p_compare = ''
    assign p_rating = '4.9'
    assign p_reviews = '204'
    assign p_short = "The ultimate multitasking natural rescue for skin that needs urgent care. A concentrated 100% natural healing balm packed with 9 powerful botanical oils — including rare sea buckthorn, shea butter, calendula and St. John's Wort — to deeply repair, soothe and protect even the most cracked, dry or irritated skin."
    assign img1 = 'https://static.wixstatic.com/media/bf3c53_d769d5f35799435cb9175e7357c2cc9df002.jpg/v1/fill/w_900,h_900,al_c,q_85/bf3c53_d769d5f35799435cb9175e7357c2cc9df002.jpg'
    assign img2 = img1
    assign img3 = img1
    assign img4 = img1
  else
    assign p_title = p.title
    assign p_vendor = p.vendor
    assign p_subtitle = p.metafields.custom.tagline.value
    assign p_price = p.price | money
    assign p_compare = p.compare_at_price | money
  endif
-%}

<section class="wrap">
  <nav aria-label="Breadcrumb" style="padding-block: var(--space-5); font-size: var(--fs-xs); color: var(--muted); letter-spacing: .08em; text-transform: uppercase;">
    <a href="{{ routes.root_url }}">Home</a> · <a href="/collections/personal-care">Personal Care</a> · <span>{{ p_title }}</span>
  </nav>

  <div class="pdp">
    <!-- Gallery -->
    <div class="pdp__gallery" data-gallery>
      <div class="pdp__main" data-gallery-main>
        <img src="{{ img1 }}" alt="{{ p_title }}" width="600" height="750">
      </div>
      <div class="pdp__thumbs">
        <div class="pdp__thumb is-active" data-gallery-thumb data-full="{{ img1 }}"><img src="{{ img1 }}" alt="" width="200" height="250"></div>
        <div class="pdp__thumb" data-gallery-thumb data-full="{{ img2 }}"><img src="{{ img2 }}" alt="" width="200" height="250"></div>
        <div class="pdp__thumb" data-gallery-thumb data-full="{{ img3 }}"><img src="{{ img3 }}" alt="" width="200" height="250"></div>
        <div class="pdp__thumb" data-gallery-thumb data-full="{{ img4 }}"><img src="{{ img4 }}" alt="" width="200" height="250"></div>
      </div>
    </div>

    <!-- Info -->
    <div class="pdp__info">
      <span class="pdp__vendor">{{ p_vendor | default: 'INature' }}</span>
      <h1 class="pdp__title">{{ p_title }}</h1>
      <p class="pdp__subtitle muted" style="font-size: var(--fs-base); margin: -10px 0 0;">{{ p_subtitle }}</p>

      <div class="pdp__rating">
        <span class="rating__stars" style="color: var(--accent); letter-spacing: 2px;">★★★★★</span>
        <strong style="font-size: var(--fs-sm);">{{ p_rating }}</strong>
        <span class="muted" style="font-size: var(--fs-sm);">· {{ p_reviews }} verified reviews</span>
      </div>

      <div class="pdp__price">
        {% if p_compare != blank and p_compare != p_price %}
          <span style="color: var(--muted); text-decoration: line-through; font-size: var(--fs-xl);">{{ p_compare }}</span>
        {% endif %}
        <span>{{ p_price }}</span>
        {% if p_compare != blank and p_compare != p_price %}
          <span class="pill pill-accent">Save 20%</span>
        {% endif %}
      </div>

      <p class="pdp__short">{{ p_short }}</p>

      <!-- Variant: Format -->
      <div class="pdp__variants">
        <span class="pdp__variant-label">Format</span>
        <div class="swatch-row" data-swatch-group>
          <button class="swatch is-active" type="button">9.5 g solid stick</button>
          <button class="swatch is-disabled" type="button" aria-disabled="true">Refill (soon)</button>
        </div>
      </div>

      <!-- Bundle -->
      <div class="pdp__variants">
        <span class="pdp__variant-label">Purchase option</span>
        <div class="swatch-row" data-swatch-group>
          <button class="swatch is-active" type="button">One-time</button>
          <button class="swatch" type="button">Bundle of 3 — save 15%</button>
        </div>
      </div>

      <!-- Add to cart row -->
      <div class="qty-row">
        <div class="qty" data-qty>
          <button type="button" data-qty-dec aria-label="Decrease">−</button>
          <input type="number" value="1" min="1" aria-label="Quantity">
          <button type="button" data-qty-inc aria-label="Increase">+</button>
        </div>
        <button class="btn btn-primary btn-lg btn-block" data-add-to-cart data-label="Add to bag — {{ p_price }}">
          Add to bag — {{ p_price }}
        </button>
      </div>

      <a href="#" style="text-align: center; font-size: var(--fs-sm); color: var(--muted); text-decoration: underline;">Buy with shop pay →</a>

      <!-- Perks -->
      <div class="pdp__perks">
        <div class="perk">{% render 'icon', name: 'truck' %} <span><strong>Free UK shipping over £20</strong> — £3 below. Dispatched via Evri, usually 1-3 working days.</span></div>
        <div class="perk">{% render 'icon', name: 'shield' %} <span><strong>14-day return policy.</strong> Unused, original packaging — we&apos;ll exchange or refund.</span></div>
        <div class="perk">{% render 'icon', name: 'heart' %} <span><strong>Spend £12+ → free gift.</strong> Add a Lip Balm or Diaper Rash Gel — on us.</span></div>
        <div class="perk">{% render 'icon', name: 'leaf' %} <span><strong>ETKO Cosmos · BioArge · Vegan · Cruelty-Free.</strong> 100% natural origin. Made in Türkiye.</span></div>
      </div>

      <!-- Accordion -->
      <div class="accordion mt-3">
        <details open>
          <summary>Key benefits — 9 botanical actives</summary>
          <div>
            • <strong>Sea buckthorn oil</strong> — rich in Omega-7, promotes rapid cell regeneration<br>
            • <strong>St. John&apos;s Wort oil</strong> — traditionally used to soothe inflamed, irritated skin<br>
            • <strong>Calendula oil</strong> — calming and healing for sensitive and reactive skin<br>
            • <strong>Shea butter</strong> — deeply nourishing, long-lasting moisture barrier<br>
            • <strong>Evening primrose &amp; borage</strong> — essential fatty acids for skin repair<br>
            • <strong>Vitamin E</strong> — natural antioxidant to protect and renew<br>
            • <strong>Beeswax</strong> — forms a protective barrier to lock in moisture<br>
            • Free from parabens, mineral oils, artificial fragrances and preservatives
          </div>
        </details>
        <details>
          <summary>How to use</summary>
          <div>Apply directly to clean, dry skin wherever needed — cracked heels, chapped lips, dry cuticles, rough elbows or irritated patches. The concentrated stick format means no mess, perfect portability and precise application. Reapply throughout the day as needed. Safe for the whole family.</div>
        </details>
        <details>
          <summary>Why choose INCIA SOS Stick</summary>
          <div>This concentrated stick format is ideal for handbag, gym bag or travel. A true SOS for skin that needs instant care — rapid, natural relief without the synthetic ingredients found in most repair balms.</div>
        </details>
        <details>
          <summary>Shipping &amp; returns</summary>
          <div>Dispatched from the UK via Evri. Free UK shipping on orders over £20 (£3 below). 14-day return policy on unused items in original packaging. International shipping available at checkout. SKU: MINC-000102.</div>
        </details>
      </div>
    </div>
  </div>
</section>

<!-- Mobile sticky add-to-cart -->
<div class="pdp-sticky">
  <div style="font-size: var(--fs-sm);">
    <strong>{{ p_title | truncate: 30 }}</strong><br>
    <span class="muted">{{ p_price }}</span>
  </div>
  <button class="btn btn-primary" data-add-to-cart data-label="Add to bag" type="button">Add to bag</button>
</div>

{% schema %}
{
  "name": "Product main",
  "settings": [
    { "type": "text", "id": "mock_title", "label": "Mock title (preview only)" }
  ],
  "presets": [{ "name": "Product main" }]
}
{% endschema %}
